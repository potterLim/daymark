SPRING_PROFILES_ACTIVE=production
APP_PORT=8080
MYSQL_DATABASE=daylog
MYSQL_USER=daylog
MYSQL_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DAY_LOG_REMEMBER_ME_KEY=change-this-remember-me-key
SERVER_SERVLET_SESSION_COOKIE_SECURE=true
DAY_LOG_MAIL_FROM_ADDRESS=no-reply@example.com
DAY_LOG_ALERT_WEBHOOK_URL=
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
DAY_LOG_BACKUP_NOTIFY_ON_SUCCESS=false
DAY_LOG_BACKUP_VERIFY_TABLES=flyway_schema_history,user_account,daily_log_entry
