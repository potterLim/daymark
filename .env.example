SPRING_PROFILES_ACTIVE=production
APP_PORT=8080
DAYMARK_PUBLIC_BASE_URL=https://daymark.example.com
MYSQL_DATABASE=daymark
MYSQL_USER=daymark
MYSQL_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DAYMARK_REMEMBER_ME_KEY=change-this-remember-me-key
DAYMARK_REMEMBER_ME_COOKIE_SECURE=true
SERVER_SERVLET_SESSION_COOKIE_SECURE=true
GOOGLE_CLIENT_ID=change-this-google-client-id
GOOGLE_CLIENT_SECRET=change-this-google-client-secret
DAYMARK_ALERT_WEBHOOK_URL=https://example.com/daymark-alerts
DAYMARK_BACKUP_NOTIFY_ON_SUCCESS=false
DAYMARK_BACKUP_VERIFY_TABLES=flyway_schema_history,user_account,daymark_entry
